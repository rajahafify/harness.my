{
  "name": "harness",
  "version": "0.1.2",
  "description": "Agentic harness using HTML as first-class UI. Conversation-based like Codex/Claude Code, where agents respond with rich, interactive HTML cards by default.",
  "author": "Raja Hafify",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build": "vite build && electron-builder --win",
    "preview": "vite preview",
    "test": "vitest"
  },
  "build": {
    "appId": "com.rajahafify.harness",
    "productName": "Harness",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "src/**/*",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        "portable"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "harness-${version}.exe"
    },
    "portable": {
      "artifactName": "harness-${version}.exe"
    },
    "asar": true,
    "compression": "maximum"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^1.0.0"
  }
}
