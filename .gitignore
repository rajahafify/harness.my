# =============================================================================
# .gitignore for harness.my
# =============================================================================
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# Environment variables & secrets (never commit these)
# -----------------------------------------------------------------------------
.env
.env.*
*.local
secrets/
*.pem
*.key

# =============================================================================
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
bower_components/
vendor/
jspm_packages/
.pnp/

# =============================================================================
# Build outputs, caches & generated files
# -----------------------------------------------------------------------------
dist/
build/
out/
coverage/
.next/
.nuxt/
.cache/
.parcel-cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
*.egg-info/
.eggs/

# =============================================================================
# Godot (common in this environment)
# -----------------------------------------------------------------------------
.import/
export.cfg
export_presets.cfg
*.import

# =============================================================================
# Misc temporary / backup files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo
*.old
*.orig

# =============================================================================
# Windows specific
# -----------------------------------------------------------------------------
*.exe
*.dll
*.msi
*.msm
*.msp
*.lnk
*.bat
*.cmd

# Add project-specific ignores below this line as the project grows.
